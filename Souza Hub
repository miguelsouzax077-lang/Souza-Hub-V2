--// SERVICES
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

--// KEY SYSTEM (PASTEBIN)
local pastebinURL = "https://pastebin.com/raw/u07LPtaT"
local keyAccepted = false

local gui = Instance.new("ScreenGui", game.CoreGui)

local keyFrame = Instance.new("Frame", gui)
keyFrame.Size = UDim2.new(0,300,0,150)
keyFrame.Position = UDim2.new(0.5,-150,0.5,-75)
keyFrame.BackgroundColor3 = Color3.fromRGB(20,20,20)

local keyBox = Instance.new("TextBox", keyFrame)
keyBox.Size = UDim2.new(0.8,0,0.3,0)
keyBox.Position = UDim2.new(0.1,0,0.3,0)
keyBox.PlaceholderText = "Digite sua key..."
keyBox.Text = ""

local keyBtn = Instance.new("TextButton", keyFrame)
keyBtn.Size = UDim2.new(0.5,0,0.2,0)
keyBtn.Position = UDim2.new(0.25,0,0.7,0)
keyBtn.Text = "Confirmar"

local function checkKey(k)
	local s, res = pcall(function()
		return game:HttpGet(pastebinURL)
	end)
	if s and res then
		for line in string.gmatch(res,"[^\r\n]+") do
			if line == k then
				return true
			end
		end
	end
	return false
end

keyBtn.MouseButton1Click:Connect(function()
	if checkKey(keyBox.Text) then
		keyAccepted = true
		gui:ClearAllChildren()
	else
		keyBox.Text = ""
		keyBox.PlaceholderText = "Key inválida"
	end
end)

repeat task.wait() until keyAccepted

--// MAIN GUI
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0,260,0,300)
main.Position = UDim2.new(0,20,0.3,0)
main.BackgroundColor3 = Color3.fromRGB(25,25,25)

-- título RGB
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,30)
title.Text = "Souza Premium"
title.BackgroundTransparency = 1

task.spawn(function()
	while true do
		for i = 0,1,0.01 do
			title.TextColor3 = Color3.fromHSV(i,1,1)
			task.wait()
		end
	end
end)

-- minimizar
local min = Instance.new("TextButton", main)
min.Size = UDim2.new(0,30,0,30)
min.Position = UDim2.new(1,-30,0,0)
min.Text = "-"

local minimized = false
min.MouseButton1Click:Connect(function()
	minimized = not minimized
	for _,v in pairs(main:GetChildren()) do
		if v ~= title and v ~= min then
			v.Visible = not minimized
		end
	end
	main.Size = minimized and UDim2.new(0,260,0,30) or UDim2.new(0,260,0,300)
end)

--// VARS
local flySpeed = 50
local walkSpeed = 16
local flying = false
local noclip = false
local magnetOn = false

--// BUTTON CREATOR
local function createBtn(text,pos,callback)
	local b = Instance.new("TextButton", main)
	b.Size = UDim2.new(0.8,0,0,30)
	b.Position = UDim2.new(0.1,0,0,pos)
	b.Text = text
	b.MouseButton1Click:Connect(callback)
end

--// SPEED INPUTS (SEM BUG)
local walkBox = Instance.new("TextBox", main)
walkBox.Size = UDim2.new(0.8,0,0,30)
walkBox.Position = UDim2.new(0.1,0,0,40)
walkBox.PlaceholderText = "WalkSpeed"
walkBox.ClearTextOnFocus = false

walkBox.FocusLost:Connect(function()
	local num = tonumber(walkBox.Text)
	if num then
		walkSpeed = num
		humanoid.WalkSpeed = walkSpeed
	end
	walkBox.Text = ""
end)

local flyBox = Instance.new("TextBox", main)
flyBox.Size = UDim2.new(0.8,0,0,30)
flyBox.Position = UDim2.new(0.1,0,0,80)
flyBox.PlaceholderText = "FlySpeed"
flyBox.ClearTextOnFocus = false

flyBox.FocusLost:Connect(function()
	local num = tonumber(flyBox.Text)
	if num then
		flySpeed = num
	end
	flyBox.Text = ""
end)

--// FLY
local bv, bg

local function startFly()
	flying = true
	bv = Instance.new("BodyVelocity", hrp)
	bv.MaxForce = Vector3.new(1e5,1e5,1e5)

	bg = Instance.new("BodyGyro", hrp)
	bg.MaxTorque = Vector3.new(1e5,1e5,1e5)
end

local function stopFly()
	flying = false
	if bv then bv:Destroy() end
	if bg then bg:Destroy() end
end

createBtn("Fly",120,function()
	if flying then stopFly() else startFly() end
end)

RunService.RenderStepped:Connect(function()
	if flying and bv and bg then
		local cam = workspace.CurrentCamera
		local dir = Vector3.zero

		if UIS:IsKeyDown(Enum.KeyCode.W) then dir += cam.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.S) then dir -= cam.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.A) then dir -= cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D) then dir += cam.CFrame.RightVector end

		if dir.Magnitude > 0 then
			bv.Velocity = dir.Unit * flySpeed
		else
			bv.Velocity = Vector3.zero
		end

		bg.CFrame = cam.CFrame
	end
end)

--// NOCLIP
createBtn("Noclip",160,function()
	noclip = not noclip
end)

RunService.Stepped:Connect(function()
	if noclip then
		for _,v in pairs(character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

--// MAGNET (EXATAMENTE O SEU)
local radius = 50
local fixed = {}
local welds = {}

local overlapParams = OverlapParams.new()
overlapParams.FilterType = Enum.RaycastFilterType.Blacklist
overlapParams.FilterDescendantsInstances = {character}

createBtn("Magnet",200,function()
	magnetOn = not magnetOn

	if not magnetOn then
		for obj, weld in pairs(welds) do
			if weld then weld:Destroy() end
		end
		table.clear(fixed)
		table.clear(welds)
	end
end)

RunService.Heartbeat:Connect(function()
	if not magnetOn then return end

	local parts = workspace:GetPartBoundsInRadius(hrp.Position, radius, overlapParams)

	for _, obj in pairs(parts) do
		if obj.Name == "TranspBox" and not obj.Anchored and not fixed[obj] then

			local distance = (obj.Position - hrp.Position).Magnitude
			local direction = (hrp.Position - obj.Position).Unit

			obj.AssemblyLinearVelocity = direction * 45

			if distance < 4 then
				obj.AssemblyLinearVelocity = Vector3.zero

				local weld = Instance.new("WeldConstraint")
				weld.Part0 = hrp
				weld.Part1 = obj
				weld.Parent = obj

				fixed[obj] = true
				welds[obj] = weld
			end
		end
	end
end)
