-- FUNÇÕES
function criarBotao(texto, callback)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(1,-10,0,40)
    btn.Text = texto
    btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 16
    
    btn.MouseButton1Click:Connect(callback)
end

function criarInput(placeholder)
    local box = Instance.new("TextBox", Scroll)
    box.Size = UDim2.new(1,-10,0,40)
    box.PlaceholderText = placeholder
    box.Text = ""
    box.BackgroundColor3 = Color3.fromRGB(35,35,35)
    box.TextColor3 = Color3.new(1,1,1)
    box.Font = Enum.Font.SourceSans
    box.TextSize = 16
    return box
end

-- PLAYER
local player = game.Players.LocalPlayer

-- SPEED
local speedBox = criarInput("Speed")

criarBotao("Aplicar Speed", function()
    local val = tonumber(speedBox.Text)
    if val then
        player.Character.Humanoid.WalkSpeed = val
    end
end)

-- FLY
local flySpeedBox = criarInput("Fly Speed")
local flying = false
local bv, bg

criarBotao("Fly ON/OFF", function()
    flying = not flying

    local char = player.Character
    local hrp = char:FindFirstChild("HumanoidRootPart")

    if flying then
        bv = Instance.new("BodyVelocity", hrp)
        bg = Instance.new("BodyGyro", hrp)

        bv.MaxForce = Vector3.new(9e9,9e9,9e9)
        bg.MaxTorque = Vector3.new(9e9,9e9,9e9)

        game:GetService("RunService").RenderStepped:Connect(function()
            if flying then
                local speed = tonumber(flySpeedBox.Text) or 60
                bv.Velocity = workspace.CurrentCamera.CFrame.LookVector * speed
                bg.CFrame = workspace.CurrentCamera.CFrame
            end
        end)
    else
        if bv then bv:Destroy() end
        if bg then bg:Destroy() end
    end
end)

-- NOCLIP
local noclip = false

criarBotao("Noclip ON/OFF", function()
    noclip = not noclip

    game:GetService("RunService").Stepped:Connect(function()
        if noclip and player.Character then
            for _,v in pairs(player.Character:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end
        end
    end)
end)

-- MAGNET (VERSÃO MAIS ESTÁVEL)
local magnet = false

criarBotao("Magnet ON/OFF", function()
    magnet = not magnet

    while magnet do
        task.wait(0.1)

        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local hrp = char.HumanoidRootPart

            for _,obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and not obj.Anchored then
                    if (obj.Position - hrp.Position).Magnitude < 50 then
                        obj.CFrame = hrp.CFrame
                    end
                end
            end
        end
    end
end)

