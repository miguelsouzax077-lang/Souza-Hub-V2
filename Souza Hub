-- ================= CONFIG =================
local KEY_URL = "https://pastebin.com/raw/u07LPtaT" -- ex: raw github

local saveFile = "souza_key.txt"

-- ================= SERVICES =================
local plr = game.Players.LocalPlayer
local uis = game:GetService("UserInputService")
local run = game:GetService("RunService")

-- ================= FUNÇÕES KEY =================
local function getKeys()
	local success, result = pcall(function()
		return game:HttpGet(KEY_URL)
	end)
	
	if success then
		return result
	end
	
	return ""
end

local function checkKey(key, data)
	for line in string.gmatch(data, "[^\r\n]+") do
		if line == key then
			return true
		end
	end
	return false
end

local function saveKey(key)
	if writefile then
		writefile(saveFile, key)
	end
end

local function loadKey()
	if readfile and isfile and isfile(saveFile) then
		return readfile(saveFile)
	end
	return nil
end

